<body class="bg-gray-50 flex items-center justify-center min-h-screen">
    <div class="bg-white p-8 rounded-2xl shadow-xl w-full max-w-md border border-gray-100">
        <h2 class="text-3xl font-bold text-sky-600 mb-6">Login</h2>
        <% if (error) { %> <p class="text-red-500 mb-4 text-sm"><%= error %></p> <% } %>
        <form action="/login" method="POST" class="space-y-4">
            <div>
                <label class="block text-sm font-medium text-gray-700">Username</label>
                <input type="text" name="username" class="w-full p-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-sky-500 outline-none">
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700">Password</label>
                <input type="password" name="password" class="w-full p-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-sky-500 outline-none">
            </div>
            <button type="submit" class="w-full py-3 bg-sky-500 text-white rounded-lg font-bold hover:bg-sky-600 transition">
                Sign In
            </button>
        </form>
    </div>
</body>
